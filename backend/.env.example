# Axon Backend Environment Variables
# Copy this to .env and fill in your values

# App
DEBUG=true

# Database (Supabase — get connection string from Supabase Dashboard → Settings → Database)
# Use "Transaction mode" pooler URL (port 6543) for best performance
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0
DATABASE_SYNC_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Google Gemini API (free tier — get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# File Storage
UPLOAD_DIR=uploads

# CORS (frontend URL)
CORS_ORIGINS=["http://localhost:3000"]

# Session
SESSION_TTL_SECONDS=7200
SESSION_SOFT_LIMIT_MINUTES=30
